# Panopticon agent secrets
# Fill in before creating tasks. This file is injected into task containers as environment variables.
#
# Claude authentication — one of:
# CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=
#
# Codex / OpenAI authentication — one of:
# CODEX_API_KEY=
# CODEX_ACCESS_TOKEN=
# OPENAI_API_KEY=
#
# Pi provider authentication — uncomment one supported provider variable, for example:
# ANTHROPIC_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# See docs/auth.md for Pi's full supported list and subscription auth.json setup.
#
# GitHub access token (for creating/reading PRs, issues, etc.)
# GH_TOKEN=
